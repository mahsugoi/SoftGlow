---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <header id="hdr">
    <a href="#hero" style="text-decoration:none;color:inherit">
    <div class="logo">
      <img src="/logo.png" alt="GlowHolder" width="48" height="48">
      <span class="brand-name">SOFGLOW</span>
      <span class="brand-divider">|</span>
      <span class="brand-product">GlowHolder</span>
    </div>
    </a>
    <nav>
      <ul>
        <li><a href="#about">About</a></li>
        <li><a href="#product">Produk</a></li>
      </ul>
      <a href="https://wa.me/6281248924820?text=Halo%20GlowHolder%2C%20saya%20tertarik%20dengan%20produk%20lampunya!%20Boleh%20minta%20info%20lebih%20lanjut%3F" target="_blank" class="nav-cta">Order WA</a>
    </nav>
    <button class="ham" id="ham" aria-label="Buka menu"><span></span><span></span><span></span></button>
  </header>

  <div class="mob" id="mob">
    <button class="mob-x" id="mob-x" aria-label="Tutup menu"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
    <a href="#about" onclick="closeMob()">About</a>
    <a href="#product" onclick="closeMob()">Produk</a>
    <a href="https://wa.me/6281248924820?text=Halo%20GlowHolder%2C%20saya%20tertarik%20dengan%20produk%20lampunya!%20Boleh%20minta%20info%20lebih%20lanjut%3F" target="_blank" onclick="closeMob()" class="nav-cta" style="font-size:.95rem">Order WA</a>
  </div>

  <section id="hero">
    <div class="hero-l">
      <div class="eyebrow fade">Handcrafted in Indonesia</div>
      <h1 class="fade d1"><span style="color:var(--logo-brown)">Hold</span> your things.<br><strong>Glow your <span style="color:var(--logo-brown)">space</span>.</strong></h1>
      <p class="hero-sub fade d2">Organizer multifungsi dengan cahaya hangat 2700K — dirancang untuk menemani meja kerja, sudut baca, dan momen santai Anda.</p>
      <div class="actions fade d3">
        <a href="#product" class="btn-dark">Lihat Produk</a>
        <a href="https://wa.me/6281248924820?text=Halo%20GlowHolder%2C%20saya%20tertarik%20dengan%20produk%20lampunya!%20Boleh%20minta%20info%20lebih%20lanjut%3F" target="_blank" class="btn-wa">
          <svg viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.123 1.533 5.854L.057 23.812l6.093-1.497A11.96 11.96 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.893 0-3.671-.51-5.204-1.4l-.374-.22-3.861.949.983-3.762-.243-.387A10 10 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
          Order via WA
        </a>
      </div>
    </div>
    <div class="hero-r"></div>
  </section>

  <div class="marquee">
    <div class="mtrack" id="mtrack"></div>
  </div>

  <section id="about">
    <div class="wrap">
      <div class="about-grid">
        <div>
          <div class="label fade">Tentang Kami</div>
          <h2 class="fade d1">Lahir dari ide<br>tentang fungsi &amp; <em>kehangatan.</em></h2>
          <p class="body-txt fade d2">GlowHolder hadir dari keinginan untuk menciptakan produk sederhana yang tidak hanya membantu merapikan barang-barang kecil, tetapi juga menghadirkan suasana yang nyaman dalam ruangan.</p>
          <p class="body-txt fade d3">Menggabungkan fungsi organizer dan night lamp dalam satu desain minimalis, GlowHolder dibuat untuk menemani rutinitas harian dengan sentuhan hangat dan estetika yang timeless.</p>
          <p class="body-txt fade d3">Setiap produk dirancang dengan perhatian pada detail agar terasa nyaman digunakan dan menyatu dengan berbagai sudut ruang.</p>
        </div>
        <img class="about-img fade d2" src="/product-ambient.webp" alt="Suasana hangat dengan lampu kayu" loading="lazy" width="600" height="600">
      </div>
    </div>
  </section>

  <section id="product">
    <div class="wrap">
      <div class="product-grid">
        <div class="fade">
          <div class="gallery-main">
            <img id="main-img" src="/product-no-bg.webp" alt="GlowHolder Wooden LED Lamp" width="500" height="500">
          </div>
          <div class="thumbs">
            <button class="on" onclick="swap(this,'/product-no-bg.webp')">
              <img src="/product-no-bg.webp" alt="Produk" loading="lazy" width="150" height="150">
            </button>
            <button onclick="swap(this,'/product-room.webp')">
              <img src="/product-room.webp" alt="In room" loading="lazy" width="150" height="150">
            </button>
            <button onclick="swap(this,'/product-lifestyle.webp')">
              <img src="/product-lifestyle.webp" alt="Lifestyle" loading="lazy" width="150" height="150">
            </button>
          </div>
        </div>
        <div class="fade d2">
          <div class="label">Produk Unggulan</div>
          <h2 class="product-name">GlowHolder<br>Wooden LED Lamp</h2>
          <p class="desc">Lampu LED dengan rangka dari PVC pipa dan wood sheet yang difinishing natural. Cahaya warm white 2700K, tombol on/off, menggunakan baterai.</p>

          <div class="spec-row">
            <div class="spec-item"><div class="spec-val">2700K</div><div class="spec-lbl">Suhu Warna</div></div>
            <div class="spec-item"><div class="spec-val">5W</div><div class="spec-lbl">Daya</div></div>
            <div class="spec-item"><div class="spec-val">25K jam</div><div class="spec-lbl">Umur LED</div></div>
            <div class="spec-item"><div class="spec-val">3 Bulan</div><div class="spec-lbl">Garansi</div></div>
          </div>

          <div class="features">
            <div class="feat"><div class="feat-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg></div><div><h4>LED 2700K</h4><p>Warm white, nyaman di mata</p></div></div>
            <div class="feat"><div class="feat-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><path d="M11 20A7 7 0 0 1 9.8 6.9C15.5 4.9 17 3.5 19 2c1 2 2 4.5 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg></div><div><h4>Natural Look</h4><p>Handcrafted dengan detail</p></div></div>
            <div class="feat"><div class="feat-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10"/></svg></div><div><h4>Tombol &amp; Baterai</h4><p>On/off, praktis tanpa kabel</p></div></div>
            <div class="feat"><div class="feat-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg></div><div><h4>Eco-Friendly</h4><p>Cat water-based, aman</p></div></div>
          </div>

          <a href="https://wa.me/6281248924820?text=Halo%20GlowHolder%2C%20saya%20tertarik%20dengan%20produk%20lampunya!%20Boleh%20minta%20info%20lebih%20lanjut%3F" target="_blank" class="btn-wa">
            <svg viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.123 1.533 5.854L.057 23.812l6.093-1.497A11.96 11.96 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.893 0-3.671-.51-5.204-1.4l-.374-.22-3.861.949.983-3.762-.243-.387A10 10 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
            Order via WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>

  <section id="order">
    <div class="wrap order-inner">
      <div class="label fade" style="color:var(--caramel);justify-content:center;display:flex">Cara Order</div>
      <h2 class="fade d1" style="color:var(--white)">Mudah &amp; <em>cepat.</em></h2>
      <p class="order-sub fade d2">Chat WhatsApp, konfirmasi, transfer, kirim. Selesai!</p>
      <div class="steps fade d2">
        <div class="step">
          <div class="step-n">1</div>
          <h4>Chat WA</h4>
          <p>Klik tombol di bawah, pesan otomatis terisi</p>
        </div>
        <div class="step">
          <div class="step-n">2</div>
          <h4>Konfirmasi</h4>
          <p>Admin balas cepat, konfirmasi stok</p>
        </div>
        <div class="step">
          <div class="step-n">3</div>
          <h4>Transfer</h4>
          <p>BCA / GoPay / OVO / COD area tertentu</p>
        </div>
        <div class="step">
          <div class="step-n">4</div>
          <h4>Dikirim</h4>
          <p>Packing aman, dikirim hari yang sama</p>
        </div>
      </div>
      <a href="https://wa.me/6281248924820?text=Halo%20GlowHolder%2C%20saya%20tertarik%20dengan%20produk%20lampunya!%20Boleh%20minta%20info%20lebih%20lanjut%3F" target="_blank" class="btn-wa-big fade d3">
        <svg viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.123 1.533 5.854L.057 23.812l6.093-1.497A11.96 11.96 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.893 0-3.671-.51-5.204-1.4l-.374-.22-3.861.949.983-3.762-.243-.387A10 10 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
        Chat WhatsApp Sekarang
      </a>
      <p class="order-note fade">Senin&ndash;Sabtu 08.00&ndash;21.00 WIB</p>
    </div>
  </section>

  <footer>
    <img class="f-logo" src="/logo.png" alt="GlowHolder" width="48" height="48">
    <p class="f-sub">Warm light for quiet moments.</p>
    <div class="f-links">
      <a href="#about">About</a>
      <a href="#product">Produk</a>
      <a href="#order">Cara Order</a>
      <a href="https://wa.me/6281248924820?text=Halo%20GlowHolder%2C%20saya%20tertarik%20dengan%20produk%20lampunya!%20Boleh%20minta%20info%20lebih%20lanjut%3F" target="_blank" rel="noopener">WhatsApp</a>
    </div>
    <p class="f-copy">&copy; 2025 GlowHolder. Proyek mahasiswa &mdash; dibuat dengan cinta</p>
  </footer>

  <div class="ig-float">
    <a href="https://www.instagram.com/sofglow.id?igsh=aW9zNXlsa3diZWx4" target="_blank" rel="noopener" aria-label="Instagram">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
        <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
        <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
      </svg>
    </a>
  </div>

  <div class="ai-float" id="aiFab">
    <button onclick="toggleAI()" aria-label="Tanya AI">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 2l2 7h7l-5.5 4 2 7L12 16l-5.5 4 2-7L3 9h7z"/>
      </svg>
    </button>
  </div>

  <div class="ai-overlay" id="aiOverlay" onclick="closeAI()"></div>

  <div class="ai-panel" id="aiPanel">
    <div class="ai-header">
      <div class="ai-header-left">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
          <path d="M12 2l2 7h7l-5.5 4 2 7L12 16l-5.5 4 2-7L3 9h7z"/>
        </svg>
        <span>GlowBot</span>
      </div>
      <button class="ai-close" onclick="closeAI()"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
    </div>
    <div class="ai-body" id="aiBody">
      <div class="ai-msg ai-bot">
        <div class="ai-msg-content">
          Halo! Saya asisten GlowHolder. Ada yang bisa saya bantu tentang produk lampu organizer multifungsi kami?
        </div>
      </div>
      <div class="ai-typing" id="aiTyping" style="display:none">
        <span></span><span></span><span></span>
      </div>
    </div>
    <div class="ai-footer">
      <input type="text" id="aiInput" placeholder="Tanya tentang GlowHolder..." autocomplete="off">
      <button id="aiSend" onclick="sendAI()" aria-label="Kirim">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
          <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
        </svg>
      </button>
    </div>
  </div>

  <script src="/src/scripts/main.js"></script>
</BaseLayout>
